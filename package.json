{
	"devDependencies": {
		"concurrently": "^9.1.2",
		"tailwindcss": "^4.1.5",
		"ts-loader": "^9.5.2",
		"typescript": "^5.8.3",
		"webpack": "^5.99.7",
		"webpack-cli": "^6.0.1"
	},
	"dependencies": {
		"@tailwindcss/cli": "^4.1.5",
		"@tailwindcss/vite": "^4.1.5"
	},
	"scripts": {
		"watch:webpack": "webpack --watch",
		"watch:css": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
